rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Demo fallback so seller access works even if role doc is not yet synced.
    function isSellerEmail() {
      return signedIn() && request.auth.token.email == "justinegaming017@gmail.com";
    }

    function isSeller() {
      return isSellerEmail() || (
        signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "seller"
      );
    }

    match /users/{userId} {
      // Owner can create own profile. Role is restricted to buyer unless seller email bootstrap.
      allow create: if isOwner(userId)
        && request.resource.data.email is string
        && (
          request.resource.data.role == "buyer"
          || (isSellerEmail() && request.resource.data.role == "seller")
        );

      allow read: if isOwner(userId) || isSeller();

      // Owner can update profile fields but cannot self-promote role to seller.
      allow update: if (
        isOwner(userId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["name", "address", "mobile", "image", "email", "role"])
        && (
          !request.resource.data.diff(resource.data).changedKeys().hasAny(["role"])
          || request.resource.data.role == resource.data.role
        )
      ) || isSeller();

      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if true;

      allow create, delete: if isSeller();

      // Seller can edit all fields.
      // Buyers can only update stock/sold during checkout or rating aggregate fields.
      allow update: if isSeller()
        || (
          signedIn()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["stock", "sold"])
          && request.resource.data.stock is number
          && request.resource.data.sold is number
          && request.resource.data.stock >= 0
          && request.resource.data.sold >= resource.data.sold
          && request.resource.data.stock <= resource.data.stock
        )
        || (
          signedIn()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["ratingAverage", "ratingCount"])
          && request.resource.data.ratingAverage is number
          && request.resource.data.ratingCount is number
          && request.resource.data.ratingAverage >= 0
          && request.resource.data.ratingAverage <= 5
          && request.resource.data.ratingCount >= 0
        );
    }

    match /transactions/{txId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.items is list
        && request.resource.data.total is number
        && request.resource.data.paymentMethod is string
        && request.resource.data.deliveryMethod is string;

      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || isSeller());

      // Seller can manage fulfillment statuses.
      allow update: if isSeller();
      allow delete: if false;
    }

    match /ratings/{ratingId} {
      allow read: if true;

      // Create or overwrite own rating document.
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.productId is string
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;

      // Update allowed only for owner, while still validating rating range.
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;

      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
